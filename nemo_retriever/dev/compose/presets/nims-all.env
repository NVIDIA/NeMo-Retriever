COMPOSE_PROFILES=nims-all
NIM_PAGE_ELEMENTS_URL=http://nim-page-elements:8000/v1/infer
NIM_TABLE_STRUCTURE_URL=http://nim-table-structure:8000/v1/infer
NIM_OCR_URL=http://nim-ocr:8000/v1/infer
NIM_EMBED_URL=http://nim-embedding:8000/v1/embeddings
NIM_EMBED_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2
NIM_CAPTION_URL=http://nim-caption:8000/v1/chat/completions
NIM_CAPTION_MODEL_YAML=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning
ANSWER_LLM_ENABLED=true
ANSWER_LLM_API_BASE_YAML=http://nim-answer:8000/v1
ANSWER_LLM_MODEL=openai/nvidia/llama-3.3-nemotron-super-49b-v1.5
ANSWER_LLM_REASONING_ENABLED=true
NIM_AUDIO_GRPC_ENDPOINT=nim-audio:50051
NIM_AUDIO_GRPC_ENDPOINT_YAML=nim-audio:50051
INSTALL_FFMPEG=true
