# Do not combine this preset with nims-core or nims-all.
LOCAL_MODELS_ENABLED=true
LOCAL_MODELS_HF_CACHE_DIR_YAML=/var/cache/huggingface
LOCAL_MODELS_DEVICE_YAML=cuda
LOCAL_MODELS_WARMUP_ON_STARTUP=true
LOCAL_MODELS_MAX_TASKS_PER_CHILD=10000
LOCAL_MODELS_MAX_PROCESS_POOL_WORKERS=1
LOCAL_EXTRACT_ENABLED=true
LOCAL_EMBED_ENABLED=true
LOCAL_ASR_ENABLED=true
LOCAL_EMBED_BACKEND=hf
LOCAL_EMBED_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2
LOCAL_EMBED_GPU_MEMORY_UTILIZATION=0.45
PIPELINE_REALTIME_WORKERS=1
PIPELINE_BATCH_WORKERS=1
NIM_PAGE_ELEMENTS_URL=
NIM_TABLE_STRUCTURE_URL=
NIM_OCR_URL=
NIM_EMBED_URL=
