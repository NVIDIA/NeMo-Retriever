# Page-elements and table-structure detection are served by the single combined
# object-detection NIM, so both endpoints resolve to the same container.
NIM_PAGE_ELEMENTS_URL=http://nim-object-detection:8000/v1/infer
NIM_TABLE_STRUCTURE_URL=http://nim-object-detection:8000/v1/infer
NIM_OCR_URL=http://nim-ocr:8000/v1/infer
NIM_EMBED_URL=http://nim-embedding:8000/v1/embeddings
